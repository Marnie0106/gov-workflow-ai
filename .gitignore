backend/uploads/*
!backend/uploads/.gitkeep

# Build output
dist/
dist-ssr/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.~
.~*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# WorkBuddy internal
.workbuddy/

# Vite temp
*.local

# 汇报资料（不上传）
汇报资料/

# 结项材料（含个人信息，不上传）
结项材料/

# 用户手册（含内部信息）
用户手册.md

